# ===== Coleta =====
# Lojas ativas (separadas por virgula): mercadolivre,amazon,shopee
ENABLED_STORES=mercadolivre,amazon,shopee

# Cron da coleta automatica do worker. Padrao: a cada 30 minutos.
COLLECT_CRON=*/30 * * * *

# ===== Scraping =====
# true = navegador sem janela (producao). false = mostra a janela (debug).
HEADLESS=true

# Caminho do arquivo de dados (JSON local).
DB_PATH=./data/coupons.json
