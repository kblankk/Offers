# ===== Coleta =====
# Lojas ativas (separadas por virgula): mercadolivre,amazon,shopee
ENABLED_STORES=mercadolivre,amazon,shopee

# Intervalo da coleta automatica, em minutos. Padrao: 5 (mais frescor).
COLLECT_INTERVAL_MIN=5

# Canais publicos de cupom no Telegram para varrer (separados por virgula).
TELEGRAM_CHANNELS=economizandocomjp,pechinchou,promobit,cuponomia,ofertasdodia,cupomdedesconto,achadinhosshopee,cuponzeiros,ofertasrelampago,economizaai,ofertasdoluan

# Caminho do arquivo de dados (JSON local — usado se NAO houver Supabase).
DB_PATH=./data/coupons.json

# ===== Persistencia duravel (opcional, gratis) =====
# Se preenchidas, os cupons sao guardados no Supabase (Postgres) e SOBREVIVEM
# aos deploys do Render. Se vazias, usa o arquivo local acima.
# Crie a tabela no SQL Editor do Supabase:
#   create table if not exists app_state (key text primary key, data jsonb not null, updated_at timestamptz default now());
SUPABASE_URL=
SUPABASE_KEY=

